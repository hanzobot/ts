// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

BOT_CODE_SIGN_STYLE = Automatic
BOT_DEVELOPMENT_TEAM = YOUR_TEAM_ID

BOT_APP_BUNDLE_ID = ai.hanzo.bot.client
BOT_SHARE_BUNDLE_ID = ai.hanzo.bot.client.share
BOT_ACTIVITY_WIDGET_BUNDLE_ID = ai.hanzo.bot.client.activitywidget
BOT_WATCH_APP_BUNDLE_ID = ai.hanzo.bot.client.watchkitapp
BOT_WATCH_EXTENSION_BUNDLE_ID = ai.hanzo.bot.client.watchkitapp.extension

// Leave empty with automatic signing.
BOT_APP_PROFILE =
BOT_SHARE_PROFILE =
